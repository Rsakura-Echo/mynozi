# mynozi 环境配置
# 复制此文件为 .env 后修改实际值

# ── HuggingFace ──
# pyannote 说话人分离所需 token（必填，否则所有人归为同一说话人）
# 在 https://huggingface.co/settings/tokens 创建 token
hf_token=

# HuggingFace 镜像（国内用户推荐）
# HF_ENDPOINT=https://hf-mirror.com

# ── RunningHub API ──
# 可在前端设置页（齿轮图标）中配置，也可在此设置默认值
# runninghub_api_key=
# runninghub_workflow_id=

# ── ASR 调优 ──
# 设备选择: auto / cpu / cuda / mps
# asr_device=auto
# 聚类阈值（0-1，越低=识别更多说话人，默认 0.50）
# pyannote_clustering_threshold=0.50
# 最小聚类大小（降低=短台词也能识别为独立说话人，默认 5）
# pyannote_min_cluster_size=5
