# ── HuggingFace 模型下载 ──
# 镜像地址（国内必设，否则连不上 huggingface.co）
HF_ENDPOINT=https://hf-mirror.com

# 下载完成后可改为 1，彻底断网使用本地模型（首次下载时必须为 0）
# HF_HUB_OFFLINE=0

# ── HuggingFace Token（说话人分离需要）──
# 获取步骤（免费，一次操作）：
#   1. 注册 huggingface.co → Settings → Access Tokens → 创建 token
#   2. 同意两个模型使用协议（点按钮即可）：
#      https://huggingface.co/pyannote/speaker-diarization-3.1
#      https://huggingface.co/pyannote/segmentation-3.0
#   3. 把 token 粘贴到下面
hf_token=your_huggingface_token_here

# ── RunningHub 配置（也可在前端 ⚙ 菜单中设置）──
# runninghub_api_key=
# runninghub_workflow_id=

# ── ASR 说话人分离调优（可选）──
# pyannote 聚类阈值：越低 = 越多聚类 = 识别更多说话人（默认 0.50）
# pyannote_clustering_threshold=0.50
# 最小聚类大小：低于此值的短台词说话人也会被识别（默认 5）
# pyannote_min_cluster_size=5
